@startuml
hide footbox
skinparam Style strictuml
skinparam ArrowFontStyle normal

participant ":FindCommand" as FC
participant "students:StudentList" as SL
participant "s:Student" as S
participant "ui:Ui" as UI

[-> FC : execute(students, ui)
activate FC

FC -> SL : getAllActive()
activate SL
return activeList

loop for each student s in activeList
    FC -> S : getName()
    activate S
    return name
    FC -> S : getSubject()
    activate S
    return subject
    FC -> S : getAcademicLevel()
    activate S
    return level
    note right: if match with find parameters, add to results
end

FC -> SL : getAllArchived()
activate SL
return archivedList

note over FC, S : Repeat search loop for archivedList

FC -> UI : showFindResults(results)
activate UI
deactivate UI

[<-- FC
deactivate FC
destroy FC
@enduml